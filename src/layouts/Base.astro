---
import { getSiteData } from '../lib/portfolio';

interface Props {
  title?: string;
  description?: string;
}

const site = getSiteData();
const {
  title = `${site.name} — ${site.role}`,
  description = site.description,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isAbout = Astro.url.pathname === '/about';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="site-wrap">
    <nav class="site-nav">
      <a href="/" class="site-nav__home">Theo Olesen, Designer.</a>
      <div class="site-nav__links">
        <a href="/about" class="site-nav__link" aria-current={isAbout ? 'page' : undefined}>About</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>{site.location}</span>
      <span>© {new Date().getFullYear()}</span>
    </footer>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
