---
import Base from '../layouts/Base.astro';
---
<Base title="About — Theo Olesen" description="Theo Olesen is a Brand Architect working in brand identity, web, and typography.">
  <div class="about">
    <div class="about__photo">
      <!-- Replace with your photo -->
      <img src="/images/theo.jpg" alt="Theo Olesen" />
    </div>

    <div class="about__content">
      <h1 class="about__name">Theo Olesen</h1>
      <p class="about__title">Brand Architect</p>

      <p class="about__bio">
        <!-- Replace with your bio -->
        I craft identities for brands that mean something. Working across brand identity, web, and typography — I build the visual language that makes a company recognizable, trusted, and impossible to ignore.
      </p>

      <div>
        <p class="about__section-label">Selected Clients</p>
        <ul class="about__clients">
          <!-- Replace with your clients -->
          <li>Client One</li>
          <li>Client Two</li>
          <li>Client Three</li>
          <li>Client Four</li>
          <li>Client Five</li>
        </ul>
      </div>

      <div class="about__contact">
        <p class="about__section-label">Contact</p>
        <a href="mailto:theoolesen@gmail.com">theoolesen@gmail.com</a>
      </div>
    </div>
  </div>
</Base>
