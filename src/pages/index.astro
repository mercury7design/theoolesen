---
import Base from '../layouts/Base.astro';
import PortfolioMedia from '../components/PortfolioMedia.astro';
import { getProjects, getWorkIntro } from '../lib/portfolio';

const projects = getProjects();
const workIntro = getWorkIntro();
---
<Base>
  <section class="work-intro">
    <p>{workIntro}</p>
  </section>

  <section class="work-grid" aria-label="Selected work">
    {projects.map((project, index) => (
      <a
        href={`/work/${project.slug}`}
        class:list={[
          'project-card',
          project.gridSize === 'hero' && 'project-card--hero',
        ]}
      >
        <div class="project-card__thumb">
          <PortfolioMedia
            asset={project.thumbnailAsset}
            src={project.thumbnail}
            alt={project.title}
            animated={project.thumbnail?.endsWith('.gif')}
            loading={index < 3 ? 'eager' : 'lazy'}
            sizes={project.gridSize === 'hero'
              ? '(min-width: 1100px) 48vw, 100vw'
              : '(min-width: 1100px) 31vw, (min-width: 700px) 48vw, 100vw'}
            class="project-card__image"
          />
        </div>
        <div class="project-card__meta">
          <span class="project-card__title">{project.title}</span>
          <span class="project-card__category">{project.category}</span>
        </div>
      </a>
    ))}
  </section>
</Base>
